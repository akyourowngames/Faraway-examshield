# EXAMSHIELD Broadcast Agent Configuration

# Telegram Provider Configuration
# The agent will look for credentials here or in the channels.json configuration file.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_default_chat_id_here

# Web Dashboard Integration
EXAMSHIELD_WEB_URL=http://localhost:3000

# Directory override for JSON configuration files (optional)
# Defaults to the config/ directory under the application root.
# BROADCAST_CONFIG_DIR=./config
